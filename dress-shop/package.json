    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@yarflam/potion-base-8m": "^1.0.4",
    "agentfootprint": "file:../../agentfootprint",
    "agentthinkingui": "file:../../agentThinkingUI",
    "hcifootprint": "file:../../hcifootprint"
  }
